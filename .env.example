# Database Configuration (Prisma)
DATABASE_URL=postgresql://postgres:password123@postgres:5432/ecommerce

# Alternative individual settings (for reference)
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password123
DB_NAME=ecommerce

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379

# JWT Configuration (CHANGE THIS IN PRODUCTION!)
JWT_SECRET=your-super-secret-jwt-key-change-in-production-minimum-256-bit
JWT_EXPIRE=7d

# Service URLs
USER_SERVICE_URL=http://user-service:5001
PRODUCT_SERVICE_URL=http://product-service:5002
ORDER_SERVICE_URL=http://order-service:5003

# API Gateway
PORT=5000
ALLOWED_ORIGINS=*

# Logging
LOG_LEVEL=info
SERVICE_NAME=api-gateway

# Node Environment
NODE_ENV=production
